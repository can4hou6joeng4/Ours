{
  "name": "ours-app",
  "version": "1.0.0",
  "private": true,
  "description": "Task and Store Management Mini Program",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "framework": "react"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build:weapp": "taro build --type weapp",
    "dev:weapp": "taro build --type weapp --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,scss}\"",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@babel/runtime": "^7.20.0",
    "@taroify/core": "^0.9.0",
    "@taroify/icons": "^0.9.0",
    "@tarojs/components": "4.1.11",
    "@tarojs/helper": "4.1.11",
    "@tarojs/plugin-framework-react": "4.1.11",
    "@tarojs/plugin-platform-weapp": "4.1.11",
    "@tarojs/react": "4.1.11",
    "@tarojs/runtime": "4.1.11",
    "@tarojs/shared": "4.1.11",
    "@tarojs/taro": "4.1.11",
    "@tarojs/webpack5-runner": "^4.1.11",
    "dayjs": "^1.11.19",
    "react": "18.0.0",
    "react-dom": "18.0.0",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-react": "^7.18.6",
    "@tarojs/cli": "4.1.11",
    "@types/jest": "^30.0.0",
    "@types/node": "^18.0.0",
    "@types/react": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "babel-preset-taro": "4.1.11",
    "eslint": "^8.41.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-taro": "^4.2.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jest": "^30.3.0",
    "postcss": "^8.4.18",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "typescript": "^5.0.0",
    "webpack": "5.91.0"
  },
  "overrides": {
    "react": "18.0.0",
    "react-dom": "18.0.0"
  }
}
